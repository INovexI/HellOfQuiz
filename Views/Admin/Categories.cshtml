@model List<HellOfQuiz.Models.Category>
@{ ViewData["Title"] = "Kategori Yönetimi"; }

<div class="admin-container">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem">
        <div>
            <h1 class="page-title">📂 Kategori Yönetimi</h1>
            <p style="color:var(--text-muted)">Toplam @Model.Count kategori</p>
        </div>
        <a href="/Admin/CreateCategory" class="btn btn-primary">➕ Yeni Kategori</a>
    </div>

    <div class="categories-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
        @foreach (var cat in Model)
        {
            <div class="category-card" style="--card-color: @cat.Color; padding: 1.25rem;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                    <span class="category-icon" style="font-size:2rem;margin-bottom:0.5rem">@cat.Icon</span>
                    <form asp-action="DeleteCategory" asp-controller="Admin" method="post" onsubmit="return confirm('Bu kategoriyi silmek istediğine emin misin? (İçindeki sorular da silinebilir!)')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cat.Id" />
                        <button type="submit" style="background:transparent;border:none;color:var(--error);cursor:pointer;font-size:1.1rem" title="Kategoriyi Sil">🗑️</button>
                    </form>
                </div>
                <div class="category-name" style="font-size:1.1rem">@cat.Name</div>
                <div class="category-count">@cat.Questions.Count Soru</div>
                <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem">
                    <div style="width:16px;height:16px;border-radius:4px;background:@cat.Color"></div>
                    <span style="font-size:0.8rem;color:var(--text-muted)">@cat.Color</span>
                </div>
            </div>
        }
    </div>
</div>
