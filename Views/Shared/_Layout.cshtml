@{
    Layout = null;
}
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HellOfQuiz</title>
    <meta name="description" content="HellOfQuiz - Arkadaşlarınla oyna, en iyisi olduğunu kanıtla!" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- NAV -->
    <nav class="navbar">
        <a href="/" class="navbar-brand">
            <span class="brand-icon">⚡</span>
            <span class="brand-text">Hell<span class="brand-accent">OfQuiz</span></span>
        </a>

        <div class="navbar-links">
            @if (Context.Session.GetString("IsAdmin") == "True")
            {
                <a href="/Admin" class="nav-link admin-link">
                    ⚙️ Admin Panel
                </a>
            }
        </div>
    </nav>

    <!-- TOAST BİLDİRİMLERİ -->
    @if (TempData["Success"] != null)
    {
        <div class="toast toast-success" id="toast">
            <span>✅</span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast toast-error" id="toast">
            <span>❌</span> @TempData["Error"]
        </div>
    }

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>⚡ <strong>HellOfQuiz</strong> &copy; 2024 &mdash; Bilgini test et, rekabete gir!</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Toast bildirimi 3 saniye sonra otomatik kapat
        const toast = document.getElementById('toast');
        if (toast) {
            setTimeout(() => {
                toast.classList.add('toast-hide');
            }, 3000);
        }
    </script>
</body>
</html>
