@model HellOfQuiz.Models.Category
@{ ViewData["Title"] = "Yeni Kategori Ekle"; }

<div class="admin-container">
    <div style="margin-bottom:1.5rem">
        <a href="/Admin/Categories" style="color:var(--text-muted);text-decoration:none;font-size:0.9rem">← Kategorilere Dön</a>
    </div>

    <div class="form-container" style="max-width:500px">
        <h1 class="form-title">📂 Yeni Kategori Ekle</h1>

        <form asp-action="CreateCategory" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color:var(--error);background:rgba(231,76,60,0.1);padding:0.75rem;border-radius:8px;margin-bottom:1rem;font-size:0.9rem"></div>

            <div class="form-group">
                <label class="form-label">Kategori Adı</label>
                <input asp-for="Name" class="form-control" placeholder="Örn: Müzik" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">İkon (Emoji)</label>
                    <input asp-for="Icon" class="form-control" placeholder="🎵" />
                    <span asp-validation-for="Icon" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Tema Rengi (Hex)</label>
                    <div style="display:flex;gap:0.5rem;align-items:center">
                        <input type="color" asp-for="Color" style="height:45px;width:50px;padding:0;border:none;border-radius:8px;background:none;cursor:pointer" />
                        <input asp-for="Color" class="form-control" style="flex:1" placeholder="#FFFFFF" />
                    </div>
                    <span asp-validation-for="Color" class="text-danger"></span>
                </div>
            </div>

            <div style="display:flex;gap:1rem;margin-top:1.5rem">
                <button type="submit" class="btn btn-primary">✅ Kaydet</button>
                <a href="/Admin/Categories" class="btn btn-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
